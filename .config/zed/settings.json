// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "auto_update_extensions": {
    "oxc": true
  },
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "gemini": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "cli_default_open_behavior": "existing_window",
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "agent": {
    "dock": "left",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "enable_thinking": true,
      "effort": "medium",
    },
    "favorite_models": [],
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": false,
    },
    "model_parameters": [],
  },
  "ssh_connections": [
    {
      "host": "devbox",
      "username": "dan",
      "projects": [
        {
          "paths": ["~/projects"],
        },
      ],
    },
    {
      "host": "devbox",
      "username": "dan",
      "projects": [],
    },
  ],
  "language_models": {
    "ollama": {
      "api_url": "http://devbox:11434",
    },
  },
  "auto_update": true,
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 11.0,
  "format_on_save": "off",
  "prettier": { "allowed": false },
  "cursor_blink": false,
  "relative_line_numbers": "enabled",
  "scrollbar": {
    "show": "always",
  },
  "project_panel": {
    "dock": "right",
    "auto_reveal_entries": true,
    "file_icons": true,
    "git_status": true,
    "indent_size": 5,
    "default_width": 200,
    "show_diagnostics": "all",
  },
  "buffer_font_features": {
    "calt": false,
    "liga": false,
  },
  "terminal": {
    "option_as_meta": true,
    "font_features": {
      "ligatures": false,
    },
  },
  "languages": {
    "PHP": {
        "language_servers": ["intelephense", "!phpactor", "!phptools"]
    },
    "JavaScript": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        },
        {
          "code_action": "source.fixAll.oxc"
        }
      ]
    },
    "TypeScript": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "TSX": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "Python": {
      "language_servers": ["ruff", "pyright"],
      "formatter": [
        { "code_action": "source.organizeImports.ruff" },
        { "code_action": "source.fixAll.ruff" },
        { "language_server": { "name": "ruff" } }
      ]
    }
  }
}
